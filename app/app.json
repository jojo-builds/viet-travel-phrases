{
  "expo": {
    "name": "Viet Phrases",
    "slug": "viet-travel-phrases",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "viet-travel-phrases",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jojobuilds.viettravelphrases",
      "buildNumber": "2",
      "infoPlist": {
        "UIStatusBarStyle": "UIStatusBarStyleDarkContent",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FAFAF8"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.jojobuilds.viettravelphrases"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "privacyPolicyUrl": "https://speaklocal.app/privacy",
      "termsOfUseUrl": "https://speaklocal.app/terms",
      "router": {},
      "eas": {
        "projectId": "a87550d4-1656-4ad3-aa90-d76272f8bb90"
      }
    },
    "owner": "jayopsai"
  }
}
