{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "preview-tagalog": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_APP_VARIANT": "tagalog"
      },
      "ios": {
        "buildConfiguration": "Release"
      }
    },
    "production": {
      "distribution": "store",
      "ios": {
        "buildConfiguration": "Release"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "alexiusxerxes@gmail.com",
        "ascAppId": "6761904350"
      }
    }
  }
}
